# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# Webhook mode (production) — set WEBHOOK_HOST; leave empty for polling (dev)
WEBHOOK_HOST=              # e.g. aut.grantsbakery.lv
WEBHOOK_PORT=8443          # port the bot listens on inside container

# ── Bot Database (new, bot-only) ───────────────────────────────
BOT_DB_HOST=bot-postgres
BOT_DB_PORT=5432
BOT_DB_NAME=grantsbot
BOT_DB_USER=botuser
BOT_DB_PASS=

# ── ERP Database (existing GBakery ERP) ───────────────────────
ERP_DB_HOST=postgres       # container name on the gbakery docker network
ERP_DB_PORT=5432
ERP_DB_NAME=gbakery
ERP_DB_USER=postgres
ERP_DB_PASS=

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://bot-redis:6379/0

# ── Anthropic (Claude Haiku) ──────────────────────────────────
ANTHROPIC_API_KEY=

# ── Klix Payments ─────────────────────────────────────────────
KLIX_BRAND_ID=
KLIX_SECRET_KEY=
KLIX_BASE_URL=https://portal.klix.app/api/v1/
KLIX_WEBHOOK_URL=          # https://<host>/webhook/klix
KLIX_SUCCESS_REDIRECT=     # https://t.me/<botusername>
KLIX_FAILURE_REDIRECT=     # https://t.me/<botusername>

# Sandbox (for testing — copy from AUTOFORGE_TASK_KLIX.md)
# KLIX_BRAND_ID=702314b8-dd86-41fa-9a22-510fdd71fa92
# KLIX_SECRET_KEY=IB-bzOdJLgJjbsaA34Qpxkg1TTIrW-iDuni6JuzbP--KgtsREHzvIvLLTH8E5T0CZcSbYM3qNmfeogpWW_RZaA==

# ── Online Shop (ERP) ─────────────────────────────────────────
# IDs of the "Online Shop" client and addresses in ERP — set after creating them
ERP_ONLINE_CLIENT_ID=
ERP_ONLINE_ADDR_PICKUP=    # client_address_id for self-pickup
ERP_ONLINE_ADDR_OMNIVA=    # client_address_id for Omniva
ERP_ONLINE_ADDR_COURIER=   # client_address_id for courier

# ── Business rules ────────────────────────────────────────────
FREEZE_CAPACITY_PCT=25     # max % of existing plan that bot can add before moving to next date
SUBSCRIPTION_DISCOUNT_THRESHOLD=3   # buhanki/week for discount to kick in
SUBSCRIPTION_DISCOUNT_PCT=5         # % discount on subscriptions
CHARGE_REMINDER_HOURS=24   # notify subscriber N hours before charge
CART_TTL_SECONDS=3600      # cart expires after 1h of inactivity
SESSION_TTL_SECONDS=86400  # session expires after 24h

# ── Misc ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development    # development | production
